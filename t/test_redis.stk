## t/test_redis.stk — assertion tests for the stryke `Redis` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_redis.{dylib,so}` on
## `use Redis`. The data-side asserts also need a live Redis at
## `$REDIS_URL` (or `127.0.0.1:6379`); they short-circuit when ping
## fails so CI without a redis container still exits clean on the
## permission-free asserts.

use Redis

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Redis::version()
assert_ok $version, "Redis::version returns truthy (cdylib loaded)"

# ── liveness probe ──────────────────────────────────────────────────
var %conn
$conn{url} = $ENV{REDIS_URL} if defined $ENV{REDIS_URL}
val $alive = eval { Redis::ping(%conn) }

if ($alive) {
    val $pfx = "stryke:test:$$"

    # 1. set / get
    Redis::set("$pfx:foo", "bar", %conn)
    assert_eq Redis::get("$pfx:foo", %conn), "bar", "set/get"

    # 2. incr
    Redis::set("$pfx:n", "10", %conn)
    assert_eq Redis::incr("$pfx:n", by => 5, %conn), 15, "incr by 5"

    # 3. mset / mget
    Redis::mset({ "$pfx:a" => "1", "$pfx:b" => "2", "$pfx:c" => "3" }, %conn)
    val @mg = Redis::mget(["$pfx:a", "$pfx:b", "$pfx:c", "$pfx:nope"], %conn)
    assert_eq scalar(@mg), 4, "mget returns 4 entries"
    assert_eq $mg[0], "1", "mget[0] = 1"
    assert_eq $mg[3], "", "mget missing key = empty string"

    # 4. expire / ttl
    Redis::set("$pfx:exp", "soon", %conn)
    Redis::expire("$pfx:exp", 100, %conn)
    val $ttl = Redis::ttl("$pfx:exp", %conn)
    assert_gt $ttl, 0, "expire/ttl > 0"
    assert_le $ttl, 100, "expire/ttl ≤ 100"

    # 5. lists
    Redis::lpush("$pfx:list", ["a", "b", "c"], %conn)
    assert_eq Redis::llen("$pfx:list", %conn), 3, "list length after lpush"
    val @lr = Redis::lrange("$pfx:list", 0, -1, %conn)
    assert_eq $lr[0], "c", "lpush reverses insertion order (head=c)"
    assert_eq $lr[2], "a", "lpush tail=a"

    # 6. sets
    Redis::sadd("$pfx:set", ["a", "b", "c"], %conn)
    assert_eq Redis::scard("$pfx:set", %conn), 3, "set cardinality"
    val @sm = sort(Redis::smembers("$pfx:set", %conn))
    assert_eq $sm[0], "a", "set smallest member"
    assert_eq $sm[2], "c", "set largest member"

    # 7. hash
    Redis::hmset("$pfx:h", { name => "alice", age => "30" }, %conn)
    val $h = Redis::hgetall("$pfx:h", %conn)
    assert_eq $h->{name}, "alice", "hash field name"
    assert_eq $h->{age}, "30", "hash field age"

    # 8. zset
    Redis::zadd("$pfx:z", { a => 1.0, b => 2.0, c => 3.0 }, %conn)
    val @zr = Redis::zrange("$pfx:z", 0, -1, withscores => 1, %conn)
    assert_eq scalar(@zr), 3, "zset has 3 entries"
    assert_eq $zr[0]->{member}, "a", "zset[0] = a (lowest score)"
    assert_near Redis::zscore("$pfx:z", "b", %conn), 2.0, 1e-9, "zscore(b) = 2.0"

    # 9. exists / del
    assert_eq Redis::exists("$pfx:foo", %conn), 1, "exists(foo) = 1"
    assert_eq Redis::del(["$pfx:foo", "$pfx:nope"], %conn), 1, "del returns 1 (only foo existed)"

    # 10. publish (no subscriber expected — count ≥ 0)
    assert_ge Redis::publish("$pfx:ch", "hello", %conn), 0, "publish returns count ≥ 0"

    # 11. type
    assert_eq Redis::type("$pfx:list", %conn), "list", "type(list-key) = list"

    # 12. scan finds our prefix
    val @keys = Redis::scan(match => "$pfx:*", count => 100, %conn)
    assert_ge scalar(@keys), 4, "scan finds ≥4 keys under our prefix"

    # 13. hash extras: hstrlen / hrandfield
    Redis::hmset("$pfx:h2", { name => "alice", role => "admin" }, %conn)
    assert_eq Redis::hstrlen("$pfx:h2", "name", %conn), 5, "hstrlen(name) = 5"
    assert_eq Redis::hstrlen("$pfx:h2", "absent", %conn), 0, "hstrlen(absent) = 0"
    val $rf = Redis::hrandfield("$pfx:h2", %conn)
    assert_ok($rf eq "name" || $rf eq "role", "hrandfield returns an existing field")

    # 14. set store variants
    Redis::sadd("$pfx:s1", ["a", "b", "c"], %conn)
    Redis::sadd("$pfx:s2", ["b", "c", "d"], %conn)
    assert_eq Redis::sinterstore("$pfx:si", ["$pfx:s1", "$pfx:s2"], %conn), 2, "sinterstore: |{b,c}| = 2"
    assert_eq Redis::sunionstore("$pfx:su", ["$pfx:s1", "$pfx:s2"], %conn), 4, "sunionstore: |{a,b,c,d}| = 4"
    assert_eq Redis::sdiffstore("$pfx:sd", ["$pfx:s1", "$pfx:s2"], %conn), 1, "sdiffstore: |{a}| = 1"

    # 15. sorted set lex range + store
    Redis::zadd("$pfx:zl", { a => 0, b => 0, c => 0, d => 0 }, %conn)
    val @lex = Redis::zrangebylex("$pfx:zl", min => "[b", max => "[c", %conn)
    assert_eq join(",", @lex), "b,c", "zrangebylex [b..[c] = b,c"
    assert_eq Redis::zlexcount("$pfx:zl", min => "-", max => "+", %conn), 4, "zlexcount full range = 4"
    Redis::zadd("$pfx:z1", { a => 1, b => 2 }, %conn)
    Redis::zadd("$pfx:z2", { b => 3, c => 4 }, %conn)
    assert_eq Redis::zunionstore("$pfx:zu", ["$pfx:z1", "$pfx:z2"], %conn), 3, "zunionstore card = 3"
    assert_eq Redis::zinterstore("$pfx:zi", ["$pfx:z1", "$pfx:z2"], %conn), 1, "zinterstore card = 1 (b)"
    assert_eq Redis::zscore("$pfx:zi", "b", %conn), 5, "zinterstore default SUM aggregate (2+3)"
    assert_eq Redis::zdiffstore("$pfx:zd", ["$pfx:z1", "$pfx:z2"], %conn), 1, "zdiffstore card = 1 (a)"

    # 16. bitpos
    Redis::set("$pfx:bits", "\xff\xf0\x00", %conn)
    assert_eq Redis::bitpos("$pfx:bits", 0, %conn), 12, "bitpos(0) = first clear bit at 12"

    # 17. lcs
    Redis::set("$pfx:l1", "ohmytext", %conn)
    Redis::set("$pfx:l2", "mynewtext", %conn)
    assert_eq Redis::lcs("$pfx:l1", "$pfx:l2", %conn), "mytext", "lcs = mytext"
    assert_eq Redis::lcs("$pfx:l1", "$pfx:l2", len => 1, %conn), 6, "lcs len = 6"

    # 18. xadd / xsetid
    Redis::xadd("$pfx:strm", { f => "v" }, id => "5-5", %conn)
    Redis::xsetid("$pfx:strm", "9-9", %conn)
    val $xi = Redis::xinfo_stream("$pfx:strm", %conn)
    assert_eq $xi->{"last-generated-id"}, "9-9", "xsetid sets last-generated-id"

    # cleanup
    val @allkeys = Redis::scan(match => "$pfx:*", count => 1000, %conn)
    Redis::del(\@allkeys, %conn) if @allkeys
}

# ── pure helpers (no connection — always run) ────────────────────────
# parse_info: structure an INFO reply string into sections/fields/names.
val $nfo = Redis::parse_info("# Server\r\nredis_version:7.4.0\r\nredis_mode:standalone\r\n\r\n# Keyspace\r\ndb0:keys=2,expires=1,avg_ttl=0\r\n")
assert_eq join(",", @{ $nfo->{names} }), "Server,Keyspace", "parse_info: section order preserved"
assert_eq $nfo->{sections}{Server}{redis_version}, "7.4.0", "parse_info: field grouped under its section"
assert_eq $nfo->{sections}{Keyspace}{db0}, "keys=2,expires=1,avg_ttl=0", "parse_info: complex value kept raw"
assert_eq $nfo->{fields}{redis_mode}, "standalone", "parse_info: flat field map spans sections"
assert_eq scalar(@{ Redis::parse_info("")->{names} }), 0, "parse_info: empty reply yields no sections"

# parse_client_info: structure a CLIENT INFO / CLIENT LIST reply.
val $ci = Redis::parse_client_info("id=3 addr=127.0.0.1:50858 name= db=0 cmd=client|info")
assert_eq scalar(@{ $ci->{clients} }), 1,           "parse_client_info: one line → one client"
assert_eq $ci->{clients}[0]{id}, "3",               "parse_client_info: id field"
assert_eq $ci->{clients}[0]{addr}, "127.0.0.1:50858", "parse_client_info: addr field"
assert_eq $ci->{clients}[0]{name}, "",              "parse_client_info: empty value preserved"
assert_eq $ci->{clients}[0]{cmd}, "client|info",    "parse_client_info: pipe in cmd survives"
val $cl = Redis::parse_client_info("id=1 db=0\nid=2 db=1\n")
assert_eq scalar(@{ $cl->{clients} }), 2,           "parse_client_info: one client per line"
assert_eq $cl->{clients}[1]{db}, "1",               "parse_client_info: second client"
assert_eq scalar(@{ Redis::parse_client_info("")->{clients} }), 0, "parse_client_info: empty reply yields no clients"

# parse_cluster_nodes: structure a CLUSTER NODES reply.
val $cn = Redis::parse_cluster_nodes("e7d1eecce10fd6bb5eb35b9f99a514335d9ba9ca 127.0.0.1:30001\@31001,host1 myself,master - 0 1700000000000 1 connected 0-5460\nabcabcabcabcabcabcabcabcabcabcabcabcabc1 127.0.0.1:30002\@31002 slave e7d1eecce10fd6bb5eb35b9f99a514335d9ba9ca 0 1700000000070 3 connected\n")
assert_eq scalar(@{ $cn->{nodes} }), 2,                  "parse_cluster_nodes: two node lines"
assert_eq $cn->{nodes}[0]{host}, "127.0.0.1",           "parse_cluster_nodes: host split from address"
assert_eq $cn->{nodes}[0]{port}, 30001,                 "parse_cluster_nodes: port parsed"
assert_eq $cn->{nodes}[0]{cport}, 31001,                "parse_cluster_nodes: cluster bus port parsed"
assert_eq $cn->{nodes}[0]{hostname}, "host1",           "parse_cluster_nodes: optional hostname"
assert_eq $cn->{nodes}[0]{role}, "master",              "parse_cluster_nodes: role from flags"
assert_ok $cn->{nodes}[0]{myself},                      "parse_cluster_nodes: myself flag"
assert_ok !defined($cn->{nodes}[0]{master}),            "parse_cluster_nodes: master `-` → undef"
assert_eq join(",", $cn->{nodes}[0]{slots}[0]->@*), "0,5460", "parse_cluster_nodes: slot range as [start,end]"
assert_eq $cn->{nodes}[1]{role}, "slave",               "parse_cluster_nodes: replica role"
assert_eq $cn->{nodes}[1]{master}, "e7d1eecce10fd6bb5eb35b9f99a514335d9ba9ca", "parse_cluster_nodes: replica's master id"

# `\@` escapes the at-sign so stryke does not array-interpolate it.
val $u = Redis::parse_url("redis://alice:s3cret\@cache.example.com:6380/2")
assert_eq $u->{scheme},   "redis",             "parse_url: scheme"
assert_eq $u->{tls},      0,                   "parse_url: redis is not tls"
assert_eq $u->{user},     "alice",             "parse_url: user"
assert_eq $u->{password}, "s3cret",            "parse_url: password"
assert_eq $u->{host},     "cache.example.com", "parse_url: host"
assert_eq $u->{port},     6380,                "parse_url: port"
assert_eq $u->{db},       2,                   "parse_url: db"
assert_eq Redis::parse_url("rediss://host")->{tls}, 1, "parse_url: rediss → tls"

# build_url: inverse of parse_url (\@ escapes the literal @ in stryke strings).
assert_eq Redis::build_url(user => "alice", password => "s3cret", host => "cache.example.com", port => 6380, db => 2), "redis://alice:s3cret\@cache.example.com:6380/2", "build_url: full round-trip"
assert_eq Redis::build_url(tls => 1, password => "pw", host => "h"), "rediss://:pw\@h", "build_url: tls + password-only userinfo"
assert_eq Redis::build_url(host => "h"), "redis://h", "build_url: bare host, no userinfo"

# redact_url: mask the password but keep the rest (safe to log; \@ escapes @).
assert_eq Redis::redact_url("redis://alice:s3cret\@cache.example.com:6380/2"), "redis://alice:***\@cache.example.com:6380/2", "redact_url: masks user:password"
assert_eq Redis::redact_url("rediss://:hunter2\@h:6379"), "rediss://:***\@h:6379", "redact_url: masks password-only userinfo"
assert_eq Redis::redact_url("redis://alice\@h/0"), "redis://alice\@h/0", "redact_url: user-only userinfo unchanged"
assert_eq Redis::redact_url("redis://h:6379/1"), "redis://h:6379/1", "redact_url: no userinfo unchanged"

assert_eq Redis::glob_match("user:*", "user:42"),         1, "glob_match: star matches"
assert_eq Redis::glob_match("user:*:s", "user:42:s"),     1, "glob_match: middle star"
assert_eq Redis::glob_match("user:*:s", "user:42:x"),     0, "glob_match: suffix mismatch"
assert_eq Redis::glob_match("h[ae]llo", "hallo"),         1, "glob_match: char class"
assert_eq Redis::glob_match("h[^e]llo", "hello"),         0, "glob_match: negated class"
assert_eq Redis::glob_match("key:[0-9]", "key:7"),        1, "glob_match: range"

# glob_escape: make metacharacters literal so glob_match matches verbatim.
assert_eq Redis::glob_escape("a*b?c"), "a\\*b\\?c", "glob_escape: escapes * and ?"
val $lit = "key:[v1]*"
assert_eq Redis::glob_match(Redis::glob_escape($lit), $lit), 1, "glob_escape: escaped literal matches itself"
assert_eq Redis::glob_match(Redis::glob_escape($lit), "key:vXYZ"), 0, "glob_escape: escaped pattern is literal, not a glob"

# glob_unescape: inverse of glob_escape.
assert_eq Redis::glob_unescape("a\\*b\\?c"), "a*b?c", "glob_unescape: decodes * and ?"
assert_eq Redis::glob_unescape("\\[d\\]"),   "[d]",   "glob_unescape: decodes [ and ]"
assert_eq Redis::glob_unescape("c\\\\d"),    "c\\d",  "glob_unescape: doubled backslash → one"
# Round-trips glob_escape.
for val $raw (q{a*b?c}, q{key:[v1]*}, q{plain}) {
    assert_eq Redis::glob_unescape(Redis::glob_escape($raw)), $raw, "glob_unescape: round-trips glob_escape($raw)"
}

# glob_to_regex: convert a Redis glob pattern to an anchored regex.
assert_eq Redis::glob_to_regex("user:*"), "^user:.*\$",   "glob_to_regex: star → .*"
assert_eq Redis::glob_to_regex("h?llo"),  "^h.llo\$",     "glob_to_regex: ? → ."
assert_eq Redis::glob_to_regex("a.b+c"),  "^a\\.b\\+c\$", "glob_to_regex: regex metacharacters escaped"
assert_eq Redis::glob_to_regex("[a-z]"),  "^[a-z]\$",     "glob_to_regex: character-class range preserved"
assert_eq Redis::glob_to_regex("[^0-9]"), "^[^0-9]\$",    "glob_to_regex: negated class preserved"
assert_dies fn { Redis::glob_to_regex("ab[cd") }, "glob_to_regex: rejects an unterminated class"

# cluster_keyslot: CLUSTER KEYSLOT — crc16(hash_tag) % 16384.
# crc16("123456789") = 0x31C3 = 12739 (standard CRC-16/XMODEM check value).
assert_eq Redis::cluster_keyslot("123456789")->{slot}, 12739, "cluster_keyslot: matches XMODEM check value"
# {tag} keys co-locate with the bare tag.
val $bare = Redis::cluster_keyslot("user1000")->{slot}
assert_eq Redis::cluster_keyslot("{user1000}.following")->{slot}, $bare, "cluster_keyslot: hash tag co-locates"
assert_eq Redis::cluster_keyslot("foo{user1000}bar")->{slot}, $bare, "cluster_keyslot: hash tag inside larger key"
assert_eq Redis::cluster_keyslot("foo{}bar")->{hash_tag}, "foo{}bar", "cluster_keyslot: empty braces hash the whole key"

# same_slot: do two keys co-locate (avoid CROSSSLOT)?
assert_eq Redis::same_slot("{user1000}.following", "{user1000}.followers")->{same_slot}, 1, "same_slot: shared hash tag co-locates"
assert_eq Redis::same_slot("user1000", "user2000")->{same_slot}, 0, "same_slot: unrelated keys differ"
assert_eq Redis::same_slot("user1000", "foo{user1000}bar")->{same_slot}, 1, "same_slot: bare tag matches embedded tag"
assert_dies fn { Redis::same_slot("x") }, "same_slot: requires two keys"

# parse_stream_id: Redis Streams entry ID "<ms>-<seq>" + special IDs.
val $sid = Redis::parse_stream_id("1526919030474-55")
assert_eq $sid->{ms},  1526919030474, "parse_stream_id: milliseconds"
assert_eq $sid->{seq}, 55,            "parse_stream_id: sequence"
assert_ok !defined(Redis::parse_stream_id("1526919030474")->{seq}), "parse_stream_id: partial id has null seq"
assert_eq Redis::parse_stream_id("-")->{special}, "min",  "parse_stream_id: - is min"
assert_eq Redis::parse_stream_id("+")->{special}, "max",  "parse_stream_id: + is max"
assert_eq Redis::parse_stream_id("\$")->{special}, "last", "parse_stream_id: \$ is last"
assert_eq Redis::parse_stream_id("*")->{special}, "auto", "parse_stream_id: * is auto"
assert_dies fn { Redis::parse_stream_id("abc-1") }, "parse_stream_id: rejects non-numeric ms"

# build_stream_id: inverse of parse_stream_id.
assert_eq Redis::build_stream_id(ms => 1526919030474, seq => 55), "1526919030474-55", "build_stream_id: ms + seq → full id"
assert_eq Redis::build_stream_id(ms => 1526919030474), "1526919030474", "build_stream_id: ms alone → partial id"
assert_eq Redis::build_stream_id(special => "min"), "-", "build_stream_id: min → -"
assert_eq Redis::build_stream_id(special => "auto"), "*", "build_stream_id: auto → *"
assert_eq Redis::build_stream_id(%{ Redis::parse_stream_id("1526919030474-55") }), "1526919030474-55", "build_stream_id: round-trips parse_stream_id"
assert_dies fn { Redis::build_stream_id(special => "bogus") }, "build_stream_id: rejects an unknown special"

# stream_id_range: inclusive XRANGE window over [start_ms, end_ms].
val $sr = Redis::stream_id_range(1000, 2000)
assert_eq $sr->{start}, "1000-0",                    "stream_id_range: start is the first id of start_ms"
assert_eq $sr->{end},   "2000-18446744073709551615", "stream_id_range: end is the last id of end_ms (max seq)"
assert_eq Redis::stream_id_range(500, 500)->{end}, "500-18446744073709551615", "stream_id_range: single-ms window spans the whole seq space"
# the bounds bracket any real id inside the window (checked via compare_stream_id)
assert_eq Redis::compare_stream_id($sr->{start}, "2000-42"), -1, "stream_id_range: start <= an id in the window"
assert_eq Redis::compare_stream_id($sr->{end},   "2000-42"),  1, "stream_id_range: end >= an id in the window"
assert_dies fn { Redis::stream_id_range(2000, 1000) }, "stream_id_range: rejects end_ms < start_ms"

# compare_stream_id: total order over stream entry IDs (ms, then seq).
assert_eq Redis::compare_stream_id("5-0", "10-0"), -1, "compare_stream_id: ms dominates"
assert_eq Redis::compare_stream_id("10-9", "5-99"), 1, "compare_stream_id: larger ms wins despite seq"
assert_eq Redis::compare_stream_id("5-1", "5-2"), -1, "compare_stream_id: equal ms → seq breaks tie"
assert_eq Redis::compare_stream_id("5-1", "5-1"), 0, "compare_stream_id: identical ids are equal"
assert_eq Redis::compare_stream_id("5", "5-0"), 0, "compare_stream_id: bare <ms> takes seq 0"
assert_eq Redis::compare_stream_id("-", "0-0"), -1, "compare_stream_id: - sorts below everything"
assert_eq Redis::compare_stream_id("+", "999999999-0"), 1, "compare_stream_id: + sorts above everything"
assert_eq Redis::compare_stream_id("-", "+"), -1, "compare_stream_id: - below +"
assert_dies fn { Redis::compare_stream_id("\$", "5-0") }, "compare_stream_id: \$ has no absolute position"
assert_dies fn { Redis::compare_stream_id("5-0", "*") }, "compare_stream_id: * has no absolute position"

# next_stream_id: successor for an exclusive XRANGE bound.
assert_eq Redis::next_stream_id("5-0"), "5-1",  "next_stream_id: increments the sequence"
assert_eq Redis::next_stream_id("5"),   "5-1",  "next_stream_id: bare <ms> takes seq 0"
assert_eq Redis::next_stream_id("5-18446744073709551615"), "6-0", "next_stream_id: seq at max rolls to next ms"
assert_eq Redis::compare_stream_id(Redis::next_stream_id("9-9"), "9-9"), 1, "next_stream_id: successor is strictly greater"
assert_dies fn { Redis::next_stream_id("-") }, "next_stream_id: - has no successor"
assert_dies fn { Redis::next_stream_id("\$") }, "next_stream_id: \$ has no successor"

# prev_stream_id: predecessor for an exclusive XREVRANGE bound (mirror of next).
assert_eq Redis::prev_stream_id("5-1"), "5-0",  "prev_stream_id: decrements the sequence"
assert_eq Redis::prev_stream_id("5"),   "4-18446744073709551615", "prev_stream_id: bare <ms> borrows to <ms-1>-MAX"
assert_eq Redis::prev_stream_id("6-0"), "5-18446744073709551615", "prev_stream_id: seq 0 borrows to previous ms"
assert_eq Redis::compare_stream_id(Redis::prev_stream_id("9-9"), "9-9"), -1, "prev_stream_id: predecessor is strictly less"
# prev/next are inverses.
assert_eq Redis::prev_stream_id(Redis::next_stream_id("1526919030474-55")), "1526919030474-55", "prev_stream_id: inverts next_stream_id"
assert_dies fn { Redis::prev_stream_id("0-0") }, "prev_stream_id: 0-0 has no predecessor"
assert_dies fn { Redis::prev_stream_id("\$") }, "prev_stream_id: \$ has no predecessor"

test_run
