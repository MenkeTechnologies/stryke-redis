## lib/Redis.stk — Redis / Valkey client for stryke (`use Redis`).
##
## Thin wrapper around the `stryke-redis` cdylib's `redis__*` exports. The
## cdylib is dlopened in-process on first `use Redis` (see stryke's
## `pkg/commands.rs::try_load_ffi_for`) and registers each export as a
## stryke-callable function via `rust_ffi::load_cdylib`. Every wrapper here
## builds a JSON args dict, calls the FFI symbol, and parses the JSON return.
##
## Replaces the v1 helper-binary model (fork(2) + exec(2) + fresh TCP
## connection per call). The cdylib caches one `redis::Connection` per
## `(url, db, auth)` tuple in `OnceCell<Mutex<HashMap>>` for the life of the
## stryke process — every `Redis::*` op now reuses the same connection
## without paying handshake cost.

package Redis

# ── error dispatch ────────────────────────────────────────────────────

## Decode the JSON returned by a `redis__*` FFI call. Dies with a
## descriptive message when the cdylib reported an error.
fn Redis::_decode ($name, $json) {
    my $o = from_json $json
    if (ref $o eq "HASH" && exists $o->{error}) {
        die "Redis::$name: $o->{error}"
    }
    $o
}

## Build the request hash: connection params from %opts plus the per-op
## fields the caller supplies. Filters out undef values so the cdylib
## applies its own defaults. Falls back to $REDIS_URL when neither
## `url` nor `host` is supplied — matches the v1 helper-binary ergonomics.
fn Redis::_req ($extra, $opts) {
    my %r = %$extra
    for my $k (qw(url host port db username password tls)) {
        $r{$k} = $opts->{$k} if exists $opts->{$k} && defined $opts->{$k}
    }
    if (!exists $r{url} && !exists $r{host} && defined $ENV{REDIS_URL}) {
        $r{url} = $ENV{REDIS_URL}
    }
    \%r
}

# ── version + ping ───────────────────────────────────────────────────

fn Redis::version {
    my $o = Redis::_decode("version", redis__version("{}"))
    $o->{version}
}

fn Redis::ping (%opts) {
    my $r = Redis::_req({}, \%opts)
    my $o = Redis::_decode("ping", redis__ping(to_json($r)))
    lc($o->{value} // "") eq "pong"
}

# ── string KV ────────────────────────────────────────────────────────

fn Redis::get ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    Redis::_decode("get", redis__get(to_json($r)))->{value}
}

## %opts may also include: ex, px, nx, xx.
fn Redis::set ($key, $value, %opts) {
    my $r = Redis::_req(
        { key => $key, value => $value, ex => $opts{ex}, px => $opts{px},
          nx => ($opts{nx} ? \1 : \0), xx => ($opts{xx} ? \1 : \0) },
        \%opts
    )
    Redis::_decode("set", redis__set(to_json($r)))->{ok}
}

fn Redis::del ($keys, %opts) {
    my $list = ref($keys) eq "ARRAY" ? $keys : [$keys]
    my $r = Redis::_req({ keys => $list }, \%opts)
    Redis::_decode("del", redis__del(to_json($r)))->{value}
}

fn Redis::exists ($keys, %opts) {
    my $list = ref($keys) eq "ARRAY" ? $keys : [$keys]
    my $r = Redis::_req({ keys => $list }, \%opts)
    Redis::_decode("exists", redis__exists(to_json($r)))->{value}
}

fn Redis::expire ($key, $seconds, %opts) {
    my $r = Redis::_req({ key => $key, seconds => $seconds }, \%opts)
    Redis::_decode("expire", redis__expire(to_json($r)))->{value}
}

fn Redis::ttl ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    Redis::_decode("ttl", redis__ttl(to_json($r)))->{value}
}

fn Redis::type ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    Redis::_decode("type", redis__type(to_json($r)))->{type}
}

fn Redis::incr ($key, %opts) {
    my $r = Redis::_req({ key => $key, by => $opts{by} }, \%opts)
    Redis::_decode("incr", redis__incr(to_json($r)))->{value}
}

fn Redis::decr ($key, %opts) {
    my $r = Redis::_req({ key => $key, by => $opts{by} }, \%opts)
    Redis::_decode("decr", redis__decr(to_json($r)))->{value}
}

fn Redis::mget ($keys, %opts) {
    my $list = ref($keys) eq "ARRAY" ? $keys : [$keys]
    my $r = Redis::_req({ keys => $list }, \%opts)
    @{ Redis::_decode("mget", redis__mget(to_json($r)))->{values} }
}

## $pairs: { k1 => v1, k2 => v2 } OR [k1, v1, k2, v2]
fn Redis::mset ($pairs, %opts) {
    my @flat
    if (ref($pairs) eq "HASH") {
        for my $k (keys %$pairs) {
            push @flat, $k, $pairs->{$k}
        }
    } elsif (ref($pairs) eq "ARRAY") {
        @flat = @$pairs
    } else {
        die "Redis::mset: pass a hashref or arrayref of pairs"
    }
    my $r = Redis::_req({ pairs => \@flat }, \%opts)
    Redis::_decode("mset", redis__mset(to_json($r)))->{ok}
}

fn Redis::keys ($pattern, %opts) {
    my $r = Redis::_req({ pattern => $pattern }, \%opts)
    @{ Redis::_decode("keys", redis__keys(to_json($r)))->{keys} }
}

fn Redis::scan (%opts) {
    my $r = Redis::_req(
        { match => $opts{match}, count => $opts{count}, limit => $opts{limit} },
        \%opts
    )
    @{ Redis::_decode("scan", redis__scan(to_json($r)))->{keys} }
}

# ── lists ────────────────────────────────────────────────────────────

fn Redis::lpush ($key, $values, %opts) {
    my $list = ref($values) eq "ARRAY" ? $values : [$values]
    my $r = Redis::_req({ key => $key, values => $list }, \%opts)
    Redis::_decode("lpush", redis__lpush(to_json($r)))->{value}
}

fn Redis::rpush ($key, $values, %opts) {
    my $list = ref($values) eq "ARRAY" ? $values : [$values]
    my $r = Redis::_req({ key => $key, values => $list }, \%opts)
    Redis::_decode("rpush", redis__rpush(to_json($r)))->{value}
}

fn Redis::lpop ($key, %opts) {
    my $r = Redis::_req({ key => $key, count => $opts{count} }, \%opts)
    my $o = Redis::_decode("lpop", redis__lpop(to_json($r)))
    defined $opts{count} ? @{ $o->{values} } : $o->{value}
}

fn Redis::rpop ($key, %opts) {
    my $r = Redis::_req({ key => $key, count => $opts{count} }, \%opts)
    my $o = Redis::_decode("rpop", redis__rpop(to_json($r)))
    defined $opts{count} ? @{ $o->{values} } : $o->{value}
}

fn Redis::lrange ($key, $start, $stop, %opts) {
    my $r = Redis::_req({ key => $key, start => $start, stop => $stop }, \%opts)
    @{ Redis::_decode("lrange", redis__lrange(to_json($r)))->{values} }
}

fn Redis::llen ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    Redis::_decode("llen", redis__llen(to_json($r)))->{value}
}

# ── sets ─────────────────────────────────────────────────────────────

fn Redis::sadd ($key, $members, %opts) {
    my $list = ref($members) eq "ARRAY" ? $members : [$members]
    my $r = Redis::_req({ key => $key, members => $list }, \%opts)
    Redis::_decode("sadd", redis__sadd(to_json($r)))->{value}
}

fn Redis::srem ($key, $members, %opts) {
    my $list = ref($members) eq "ARRAY" ? $members : [$members]
    my $r = Redis::_req({ key => $key, members => $list }, \%opts)
    Redis::_decode("srem", redis__srem(to_json($r)))->{value}
}

fn Redis::smembers ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    @{ Redis::_decode("smembers", redis__smembers(to_json($r)))->{members} }
}

fn Redis::sismember ($key, $m, %opts) {
    my $r = Redis::_req({ key => $key, member => $m }, \%opts)
    Redis::_decode("sismember", redis__sismember(to_json($r)))->{value} ? 1 : 0
}

fn Redis::scard ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    Redis::_decode("scard", redis__scard(to_json($r)))->{value}
}

# ── hashes ───────────────────────────────────────────────────────────

fn Redis::hset ($key, $field, $value, %opts) {
    my $r = Redis::_req({ key => $key, field => $field, value => $value }, \%opts)
    Redis::_decode("hset", redis__hset(to_json($r)))->{value}
}

fn Redis::hget ($key, $field, %opts) {
    my $r = Redis::_req({ key => $key, field => $field }, \%opts)
    Redis::_decode("hget", redis__hget(to_json($r)))->{value}
}

fn Redis::hdel ($key, $fields, %opts) {
    my $list = ref($fields) eq "ARRAY" ? $fields : [$fields]
    my $r = Redis::_req({ key => $key, fields => $list }, \%opts)
    Redis::_decode("hdel", redis__hdel(to_json($r)))->{value}
}

fn Redis::hgetall ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    %{ Redis::_decode("hgetall", redis__hgetall(to_json($r)))->{hash} }
}

fn Redis::hkeys ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    @{ Redis::_decode("hkeys", redis__hkeys(to_json($r)))->{keys} }
}

fn Redis::hvals ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    @{ Redis::_decode("hvals", redis__hvals(to_json($r)))->{values} }
}

fn Redis::hmget ($key, $fields, %opts) {
    my $list = ref($fields) eq "ARRAY" ? $fields : [$fields]
    my $r = Redis::_req({ key => $key, fields => $list }, \%opts)
    @{ Redis::_decode("hmget", redis__hmget(to_json($r)))->{values} }
}

## $pairs: { f1 => v1, f2 => v2 } OR [f1, v1, f2, v2]
fn Redis::hmset ($key, $pairs, %opts) {
    my @flat
    if (ref($pairs) eq "HASH") {
        for my $k (keys %$pairs) {
            push @flat, $k, $pairs->{$k}
        }
    } elsif (ref($pairs) eq "ARRAY") {
        @flat = @$pairs
    } else {
        die "Redis::hmset: pass a hashref or arrayref of pairs"
    }
    my $r = Redis::_req({ key => $key, pairs => \@flat }, \%opts)
    Redis::_decode("hmset", redis__hmset(to_json($r)))->{ok}
}

# ── sorted sets ──────────────────────────────────────────────────────

## $pairs: [score, member, score, member, ...]
fn Redis::zadd ($key, $pairs, %opts) {
    die "Redis::zadd: pairs must be arrayref" unless ref($pairs) eq "ARRAY"
    my $r = Redis::_req({ key => $key, pairs => $pairs }, \%opts)
    Redis::_decode("zadd", redis__zadd(to_json($r)))->{value}
}

fn Redis::zrange ($key, $start, $stop, %opts) {
    my $r = Redis::_req(
        { key => $key, start => $start, stop => $stop,
          with_scores => ($opts{with_scores} ? \1 : \0),
          rev => ($opts{rev} ? \1 : \0) },
        \%opts
    )
    my $o = Redis::_decode("zrange", redis__zrange(to_json($r)))
    $opts{with_scores} ? @{ $o->{pairs} } : @{ $o->{values} }
}

fn Redis::zrem ($key, $members, %opts) {
    my $list = ref($members) eq "ARRAY" ? $members : [$members]
    my $r = Redis::_req({ key => $key, members => $list }, \%opts)
    Redis::_decode("zrem", redis__zrem(to_json($r)))->{value}
}

fn Redis::zcard ($key, %opts) {
    my $r = Redis::_req({ key => $key }, \%opts)
    Redis::_decode("zcard", redis__zcard(to_json($r)))->{value}
}

fn Redis::zscore ($key, $member, %opts) {
    my $r = Redis::_req({ key => $key, member => $member }, \%opts)
    Redis::_decode("zscore", redis__zscore(to_json($r)))->{value}
}

# ── pub/sub publish ──────────────────────────────────────────────────

fn Redis::publish ($channel, $message, %opts) {
    my $r = Redis::_req({ channel => $channel, message => $message }, \%opts)
    Redis::_decode("publish", redis__publish(to_json($r)))->{value}
}

# ── server admin ─────────────────────────────────────────────────────

fn Redis::info (%opts) {
    my $r = Redis::_req({ section => $opts{section} }, \%opts)
    Redis::_decode("info", redis__info(to_json($r)))->{info}
}

fn Redis::dbsize (%opts) {
    my $r = Redis::_req({}, \%opts)
    Redis::_decode("dbsize", redis__dbsize(to_json($r)))->{value}
}

fn Redis::flushdb (%opts) {
    my $r = Redis::_req({ asynchronous => ($opts{async} ? \1 : \0) }, \%opts)
    Redis::_decode("flushdb", redis__flushdb(to_json($r)))->{ok}
}

# ── raw command escape hatch ─────────────────────────────────────────

fn Redis::raw ($argv_in, %opts) {
    my $argv = ref($argv_in) eq "ARRAY" ? $argv_in : [$argv_in]
    my $r = Redis::_req({ argv => $argv }, \%opts)
    Redis::_decode("raw", redis__raw(to_json($r)))->{value}
}

1
