fn Redis::hset ($key, $field, $value, %opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "hset", Redis::_shq($key), Redis::_shq($field), Redis::_shq($value)
    Redis::_run_json(\@argv)->{value}
}

fn Redis::hget ($key, $field, %opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "hget", Redis::_shq($key), Redis::_shq($field)
    Redis::_run_json(\@argv)->{value}
}

fn Redis::hdel ($key, $fields, %opts) {
    my @list = ref($fields) eq "ARRAY" ? @{$fields} : ($fields)
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "hdel", Redis::_shq($key)
    push @argv, Redis::_shq($_) for @list
    Redis::_run_json(\@argv)->{value}
}

# Returns a hashref { field => value, … }.
fn Redis::hgetall ($key, %opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "hgetall", Redis::_shq($key)
    Redis::_run_json(\@argv)
}

fn Redis::hkeys ($key, %opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "hkeys", Redis::_shq($key)
    @{ Redis::_run_json(\@argv)->{keys} }
}

fn Redis::hvals ($key, %opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "hvals", Redis::_shq($key)
    @{ Redis::_run_json(\@argv)->{values} }
}

fn Redis::hmget ($key, $fields, %opts) {
    my @list = ref($fields) eq "ARRAY" ? @{$fields} : ($fields)
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "hmget", Redis::_shq($key)
    push @argv, Redis::_shq($_) for @list
    @{ Redis::_run_json(\@argv)->{values} }
}

# $pairs: { field => value, … } OR [field, value, …]
fn Redis::hmset ($key, $pairs, %opts) {
    my @flat
    if (ref($pairs) eq "HASH") {
        for my $k (keys %$pairs) {
            push @flat, $k, $pairs->{$k}
        }
    } elsif (ref($pairs) eq "ARRAY") {
        @flat = @$pairs
    } else {
        die "Redis::hmset: pass a hashref or arrayref of field/value pairs"
    }
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "hmset", Redis::_shq($key)
    push @argv, Redis::_shq($_) for @flat
    Redis::_run_json(\@argv)
}

# ---------------------------------------------------------------------------
# Sorted sets
# ---------------------------------------------------------------------------

# $pairs: { member => score, … } OR [score, member, score, member, …]
fn Redis::zadd ($key, $pairs, %opts) {
    my @flat
    if (ref($pairs) eq "HASH") {
        for my $m (keys %$pairs) {
            push @flat, $pairs->{$m}, $m
        }
    } elsif (ref($pairs) eq "ARRAY") {
        @flat = @$pairs
    } else {
        die "Redis::zadd: pass a hashref { member => score } or arrayref [score, member, …]"
    }
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "zadd", Redis::_shq($key)
    push @argv, Redis::_shq($_) for @flat
    Redis::_run_json(\@argv)->{value}
}

# With `withscores => 1`, returns array of { member, score } hashrefs.
fn Redis::zrange ($key, $start, $stop, %opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "zrange", Redis::_shq($key), Redis::_shq($start), Redis::_shq($stop)
    push @argv, "--withscores" if $opts{withscores}
    push @argv, "--rev"        if $opts{rev}
    @{ Redis::_run_json(\@argv)->{values} }
}

fn Redis::zrem ($key, $members, %opts) {
    my @list = ref($members) eq "ARRAY" ? @{$members} : ($members)
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "zrem", Redis::_shq($key)
    push @argv, Redis::_shq($_) for @list
    Redis::_run_json(\@argv)->{value}
}

fn Redis::zcard ($key, %opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "zcard", Redis::_shq($key)
    Redis::_run_json(\@argv)->{value}
}

fn Redis::zscore ($key, $member, %opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "zscore", Redis::_shq($key), Redis::_shq($member)
    Redis::_run_json(\@argv)->{score}
}

# ---------------------------------------------------------------------------
# Pub/sub + server
# ---------------------------------------------------------------------------

fn Redis::publish ($channel, $message, %opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "publish", Redis::_shq($channel), Redis::_shq($message)
    Redis::_run_json(\@argv)->{value}
}

fn Redis::info (%opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "info"
    push @argv, Redis::_shq($opts{section}) if defined $opts{section}
    Redis::_run_json(\@argv)
}

fn Redis::dbsize (%opts) {
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "dbsize"
    Redis::_run_json(\@argv)->{value}
}

fn Redis::flushdb (%opts) {
    die "Redis::flushdb: pass confirm => 1 to actually flush" unless $opts{confirm}
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "flushdb", "--confirm"
    Redis::_run_json(\@argv)
}

# Run an arbitrary Redis command. $argv is an arrayref starting with the
# command name (e.g. ["XADD", "stream", "*", "k", "v"]).
fn Redis::raw ($argv_in, %opts) {
    die "Redis::raw: argv must be an arrayref" unless ref($argv_in) eq "ARRAY"
    my @argv = Redis::_conn_argv(\%opts)
    push @argv, "raw"
    push @argv, Redis::_shq($_) for @$argv_in
    Redis::_run_json(\@argv)
}

1
